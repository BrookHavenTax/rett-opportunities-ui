# ── RETT Opportunities Database — environment variables ──
#
# Copy this file to .env.local and fill in real values for production.
#
# MongoDB connection string. In LOCAL DEVELOPMENT you may leave this unset
# (or set it to "memory") — the app will automatically spin up an in-memory
# MongoDB replica set so you can run and seed the app with zero setup.
# For PRODUCTION, point this at a real MongoDB Atlas cluster.
MONGODB_URI=

# Public base URL used to build shareable "Copy Link" URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional shared secret. When set, POST /api/import requires the
# x-admin-secret request header to match this value. Leave blank to disable
# the guard (until the staff-portal SSO is wired up).
ADMIN_SECRET=
